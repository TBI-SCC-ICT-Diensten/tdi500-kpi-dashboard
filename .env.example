VITE_HUPIE_API_URL=https://hupie.northeurope.cloudapp.azure.com/hupie/query/
VITE_HUPIE_API_KEY=your-token-here
# Timeout for the list query (ms). Per-pump detail queries use 30s hardcoded in config/index.ts
VITE_API_TIMEOUT=10000
VITE_EP_ONLINE_API_KEY=your-ep-online-api-key-here
VITE_USE_MOCK_DATA=false
VITE_BAG_API_KEY=
# KNMI Data Platform API key — injected server-side via Vite proxy
# Request a key at: https://developer.dataplatform.knmi.nl/
VITE_KNMI_API_KEY=

# ── Deployment (Vercel) ──────────────────────────────────────────────────────
# Server-side only (no VITE_ prefix) — set in Vercel dashboard, not in .env
# EP_ONLINE_API_KEY is used by api/ep-online.ts in production
# In development, VITE_EP_ONLINE_API_KEY is used by vite.config.ts proxy
EP_ONLINE_API_KEY=
