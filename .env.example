# Timeout for the list query (ms). Per-pump detail queries use 30s hardcoded in config/index.ts
VITE_API_TIMEOUT=10000
VITE_USE_MOCK_DATA=false

# ── Local dev proxy secrets (vite.config.ts) ─────────────────────────────────
# VITE_ secrets here are for the LOCAL DEV PROXY ONLY — never set them in any
# Vercel scope: VITE_-prefixed vars get inlined into the client bundle. In
# production these APIs are proxied server-side via api/*.ts using the non-VITE_
# keys below.
VITE_EP_ONLINE_API_KEY=your-ep-online-api-key-here
# KNMI Data Platform API key — Request a key at: https://developer.dataplatform.knmi.nl/
VITE_KNMI_API_KEY=

# ── Deployment (Vercel) ──────────────────────────────────────────────────────
# Server-side only (no VITE_ prefix) — set in the Vercel dashboard, not in .env.
# Used by the serverless proxies in production:
#   HUPIE_API_KEY, HUPIE_API_URL  → api/hupie.ts
#   BAG_API_KEY                   → api/bag.ts
#   EP_ONLINE_API_KEY             → api/ep-online.ts
EP_ONLINE_API_KEY=
